########################################################################
# LLM CONFIGURATION
########################################################################

# Groq API key used for LLM calls



########################################################################
# GITHUB CONFIGURATION
########################################################################

# GitHub Personal Access Token (classic or fine-grained)
# Requires: repo (full control of private repositories)


# GitHub repository URL (must include .git)
GITHUB_REPO_URL=https://github.com/mohitagarwal1989/food-delivery-app.git

# Base branch to create PRs against
GITHUB_BASE_BRANCH=master


########################################################################
# LOCAL REPOSITORY CONFIG
########################################################################

# Local filesystem path where the GitHub repo is cloned
# This folder must be writable
GITHUB_LOCAL_PATH=food-delivery-app


########################################################################
# LOG SCANNING CONFIG
########################################################################

# One or more folders containing application log files
# (Comma-separated if you later want multiple folders)
LOG_FOLDERS=C:\sampleAppLog

# Log scan interval in seconds
SCAN_INTERVAL=60


########################################################################
# VECTOR DATABASE CONFIG (OPTIONAL OVERRIDES)
########################################################################

# Where ChromaDB stores exception logs
LOG_CHROMA_DB_PATH=log_chroma_db

# Where ChromaDB stores error knowledge base
ERROR_KB_DB_PATH=error_knowledge_db


########################################################################
# RUNTIME / DEBUG (OPTIONAL)
########################################################################

# Set to 1 to enable verbose debug logging
DEBUG_MODE=0